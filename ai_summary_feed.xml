        &lt;h1 style=&quot;color: #2c3e50; margin-bottom: 5px;&quot;&gt;Daily AI Literature Insights&lt;/h1&gt;
        &lt;p style=&quot;color: #7f8c8d; font-size: 0.95em; margin-top: 0;&quot;&gt;
